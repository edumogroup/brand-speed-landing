# Copy this file to .env.local (for local `vercel dev`) or paste directly into
# Vercel → Project Settings → Environment Variables (production). Never commit
# the real value — .env.local should already be in your .gitignore.

# Same key you set for this webhook inside SePay dashboard → Webhooks → Security → API Key
SEPAY_API_KEY=paste_your_sepay_api_key_here

# From @BotFather when you create the bot (see payment-setup-guide.md)
TELEGRAM_BOT_TOKEN=paste_your_telegram_bot_token_here
# Your personal chat id (from api.telegram.org/bot<token>/getUpdates after messaging the bot once)
TELEGRAM_CHAT_ID=paste_your_telegram_chat_id_here

# Web App URL from Google Apps Script (see email-and-sheet-setup-guide.md)
GOOGLE_SHEET_WEBHOOK_URL=paste_your_apps_script_web_app_url_here
# Must match SHEET_SECRET constant inside google-apps-script/leads-sheet.gs
GOOGLE_SHEET_SECRET=paste_a_random_string_here

# From resend.com → API Keys
RESEND_API_KEY=paste_your_resend_api_key_here
# Must be on a domain verified in Resend (see email-and-sheet-setup-guide.md)
RESEND_FROM_EMAIL=hello@send.brandspeed.hoanghuynh.vn
RESEND_FROM_NAME=Huynh - BRAND SPEED
